# Copy to .env.local for local development, and set the same keys in Vercel
# (Project → Settings → Environment Variables). Both are NEXT_PUBLIC_ and safe
# to expose in the browser; restrict them at the provider instead.

# Google Maps — address autocomplete on the installation booking wizard.
# Restrict the key by HTTP referrer to the FineVu domains in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Resend — sends contact / retailer / services form submissions server-side to
# support@finevuaustralia.com (via app/api/contact). SECRET — never prefix with
# NEXT_PUBLIC_, and mark it "Sensitive" in Vercel. Get the key at https://resend.com
RESEND_API_KEY=

# Optional overrides for the contact route.
# CONTACT_TO_EMAIL defaults to support@finevuaustralia.com.
# CONTACT_FROM_EMAIL must be on a domain verified in Resend once finevuaustralia.com.au
# is set up (until then Resend only permits "onboarding@resend.dev").
# CONTACT_TO_EMAIL=support@finevuaustralia.com
# CONTACT_FROM_EMAIL=FineVu Australia <no-reply@finevuaustralia.com.au>
